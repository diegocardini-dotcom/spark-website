# ─── SANITY CMS ───────────────────────────────────────────────
# Required for the editable Work section + /studio dashboard.
# Get these free at sanity.io, create a new project.
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-07-01

# ─── CONTACT FORM (Resend) ────────────────────────────────────
# Delivers lead notifications to your inbox.
# 1. resend.com, sign up (free), verify sparkdigital.agency as sender domain
# 2. Create an API key, paste below
RESEND_API_KEY=re_your_key_here
CONTACT_TO_EMAIL=hello@sparkdigital.agency
CONTACT_FROM_EMAIL=leads@sparkdigital.agency
